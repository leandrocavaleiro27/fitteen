# Copy to `.env` at project root for local Netlify dev (`npm run dev:netlify`).
# SERVER-ONLY keys must never be committed or prefixed with VITE_.

# Same URL as VITE_SUPABASE_URL in .env.local (functions accept either locally)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

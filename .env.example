# ─── CLIENT-SIDE ONLY (safe to prefix with VITE_) ───
# Copy to .env.local for local dev. Set the same names in Netlify for production builds.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

VITE_APP_URL=https://fit-teen.netlify.app

# Same Client ID as Supabase Google provider — enables popup sign-in (no Supabase URL in browser)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
